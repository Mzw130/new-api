# Copy to ".env.deploy" (gitignored) and fill in real values.
# Used by: docker compose -f docker-compose.image.yml up -d
#
# MySQL (default for Docker Compose in this repo):
# SQL_DSN=user:pass@tcp(host:3306)/dbname?parseTime=true
#
# PostgreSQL (if you use Postgres instead):
# Local / Docker without TLS: postgresql://user:pass@host:5432/dbname?sslmode=disable
# Managed DB with TLS:       postgresql://user:pass@host:5432/dbname?sslmode=require
#
# Redis example:
# REDIS_CONN_STRING=redis://:password@host:6379


SQL_DSN=
REDIS_CONN_STRING=
SESSION_SECRET=cluster_secret
CRYPTO_SECRET=cluster_secret
TZ=Asia/Shanghai
BATCH_UPDATE_ENABLED=true

# --- Split deploy SPA image (Compose `spa` → Dockerfile.web) ---
# Root compose scheme A: omit SPA_BAKED_API_ORIGIN (empty bake → same-origin + Nginx /api,/v1,… proxy).
# Cross-origin static SPA only — bake explicit API origin (then rebuild SPA):
# SPA_BAKED_API_ORIGIN=https://api.example.com
# Optional host port mapping for SPA containers:
# SPA_HOST_PORT=3003
# 若 API 用 monolith 启动、SPA 用 compose-instances，需与 API 所在网络一致：
# NEW_API_DOCKER_NETWORK=new-api_new-api-network
# SPA_CLASSIC_HOST_PORT=3001

# --- Split Classic SPA (Compose `classic-spa` → Dockerfile.web.classic) ---
# Root compose scheme A: omit SPA_CLASSIC_BAKED_API_ORIGIN (same-origin bake).
# Cross-origin static SPA only — then rebuild classic-spa:
# SPA_CLASSIC_BAKED_API_ORIGIN=https://api.example.com
#
# Nginx proxy target inside classic-spa container (runtime, no image rebuild):
# Compose + API on new-api-network (default):
# BACKEND_NEW_API=http://1router.ai:3000
# API on host / docker0 (common on cloud VPS):
# BACKEND_NEW_API=http://172.17.0.1:3002

# --- Split deploy (SPA on CDN / separate host; use with Dockerfile.api-only) ---
SERVE_EMBEDDED_FRONTEND=false
FRONTEND_BASE_URL=https://your-static-site.example.com
CORS_ALLOWED_ORIGINS=https://your-static-site.example.com
# HTTPS + split domains / subdomains (login cookie):
# SESSION_COOKIE_SAMESITE=none
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_DOMAIN=.example.com
#
# Behind nginx / LB — Gin trusted proxies (comma IPs or CIDRs):
# TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8
#
# Baseline security headers (recommended behind TLS terminator):
# ENABLE_SECURITY_HEADERS=true
# SECURITY_FRAME_OPTIONS=SAMEORIGIN
#
# Bake API into images for cross-domain static hosts (prefer these over leaking host VITE_* into Docker builds):
# SPA_BAKED_API_ORIGIN=https://api.example.com
# SPA_CLASSIC_BAKED_API_ORIGIN=https://api.example.com
#
# Unified-edge compose template: deploy/enterprise-split/