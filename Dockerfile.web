# Default-theme SPA — Nginx serves Rsbuild production dist.
#
#   docker build -f Dockerfile.web -t 1router:spa \
#     --build-arg VITE_REACT_APP_SERVER_URL=https://api.example.com .
#
# Scheme A (default in root docker-compose.yml): leave VITE_REACT_APP_SERVER_URL empty so axios
# uses same origin; deploy/split/nginx.spa.conf proxies /api, /v1, /pg, /mj → new-api:3000.

# syntax=docker/dockerfile:1
FROM oven/bun:alpine AS builder
WORKDIR /app

COPY web/default/package.json web/default/bun.lock ./
RUN bun install --frozen-lockfile

COPY web/default/ ./

ARG VITE_REACT_APP_SERVER_URL=
ENV VITE_REACT_APP_SERVER_URL=${VITE_REACT_APP_SERVER_URL}

# Invalidate BuildKit cached `RUN bun run build` after changing same-origin/API-bake semantics.
ARG SPA_API_BAKE_CACHE_BUSTER=2026-05-20-spa-env-isolation
RUN bun run build

FROM nginx:1.27-alpine

COPY deploy/split/nginx.spa.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80
